{
  "name": "web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "setup": "wrangler pages project create template-web --production-branch main 2>/dev/null || echo '↳ Pages project template-web already exists — skipping'",
    "deploy": "wrangler pages deploy dist --project-name=template-web",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@app/shared": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.0",
    "vite": "^6.0.7",
    "wrangler": "^4.0.0"
  }
}
